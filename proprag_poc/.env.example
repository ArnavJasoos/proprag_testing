# Copy to .env at the repo root and fill in. Loaded automatically by config.py.
# Default backend is the free NVIDIA-hosted API (OpenAI-compatible).
# Get a key at https://build.nvidia.com (free tier).

# --- LLM endpoint (chat) ---
NVIDIA_API_KEY=
PROPRAG_LLM_BACKEND=nvidia
PROPRAG_LLM_MODEL=meta/llama-3.3-70b-instruct

# --- Rate limit (chat LLM only) ---
# Requests per minute against the online provider. NVIDIA free tier is ~40 RPM
# (account-level, per model); 38 stays just under it for faster runs. Embeddings
# run on the local backend below by default, so this limit never applies to them.
PROPRAG_RPM_LIMIT=38

# --- Embeddings ---
# Default: a local sentence-transformers model. No API, no rate limit, no token
# cost, and every RAG system embeds with one model (fair comparison).
PROPRAG_EMBEDDING_BACKEND=sentence_transformers
PROPRAG_EMBEDDING_MODEL=BAAI/bge-large-en-v1.5

# --- Online alternative (NVIDIA-hosted nv-embedqa) ---
# Uncomment to embed via the NVIDIA API instead of locally. Shares
# PROPRAG_RPM_LIMIT with chat once enabled.
#PROPRAG_EMBEDDING_BACKEND=nvidia
#PROPRAG_EMBEDDING_MODEL=nvidia/nv-embedqa-e5-v5

# Other chat backends are also supported:
#   google | koboldcpp | ollama | vllm | openrouter
